# ------------------------------------------------------------------
# Campus Legend — environment variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` or any file containing real secrets.
# The game runs fully in GUEST/DEMO mode with NO Supabase configured.
# Supabase is only required for cloud (signed-in) career saves.
# ------------------------------------------------------------------

# Public Supabase project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"

# Public anon key (safe to expose; protected by Row Level Security)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Service role key — SERVER ONLY. Bypasses RLS. Used only by seed scripts.
# Do NOT prefix with NEXT_PUBLIC. Never ship to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Optional: enable/disable cloud auth features explicitly.
# "true" | "false" — when unset, cloud is auto-enabled if URL+anon key exist.
NEXT_PUBLIC_ENABLE_CLOUD="true"

# Optional Playwright cloud-save test credentials (leave empty to skip that e2e)
E2E_TEST_EMAIL=""
E2E_TEST_PASSWORD=""
